#!/bin/bash
# Pre-commit hook — prevent credentials, .env files, and large binaries

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "Running pre-commit checks..."
EXIT_CODE=0

# 1. Hardcoded credentials — code files only (.md and .env.example are excluded)
# Scoped to py/sh/yaml/toml/json to avoid false positives from docs/examples
if git diff --cached -- '*.py' '*.sh' '*.yaml' '*.yml' '*.toml' '*.json' \
    | grep -E '^\+' \
    | grep -v '^\+\s*#' \
    | grep -E '(password|api_key|secret|token|database_url|db_url|connection).*=.*["'"'"'][A-Za-z0-9_\-]{20,}["'"'"']' \
    | grep -v "os\.getenv" \
    | grep -v "os\.environ" \
    | grep -v '<[A-Za-z_-]*>' \
    | grep -q .; then
    echo -e "${RED}❌ ERROR: Possible credentials in staged changes${NC}"
    echo "Use .env file and os.getenv() instead."
    echo "False positive? Use: git commit --no-verify"
    EXIT_CODE=1
fi

# 2. Connection strings with embedded credentials
if git diff --cached | grep -E '^\+.*(postgresql|postgres|mysql|mongodb|redis|amqp)://[^@]*:[^@]*@' | grep -q .; then
    echo -e "${RED}❌ ERROR: Connection string with embedded credentials${NC}"
    echo "Use os.getenv('DATABASE_URL') instead."
    EXIT_CODE=1
fi

# 3. .env files (allow .env.example)
BLOCKED_ENV=$(git diff --cached --name-only | grep -E '\.env($|\.)' | grep -vE '\.env\.example$')
if [ -n "$BLOCKED_ENV" ]; then
    echo -e "${RED}❌ ERROR: Attempting to commit .env file:${NC}"
    echo "$BLOCKED_ENV"
    EXIT_CODE=1
fi

# 4. Large files (>5MB)
MAX_SIZE=5242880
for FILE in $(git diff --cached --name-only); do
    if [ -f "$FILE" ]; then
        SIZE=$(wc -c < "$FILE" | tr -d ' ')
        if [ "$SIZE" -gt "$MAX_SIZE" ]; then
            echo -e "${RED}❌ ERROR: Large file: $FILE ($(($SIZE / 1024 / 1024))MB, max 5MB)${NC}"
            echo "Use git-lfs or external storage."
            EXIT_CODE=1
        fi
    fi
done

# 5. Binary/data files that shouldn't be in a Python repo
BLOCKED_EXT="pkl|pickle|joblib|parquet|csv|tsv|json\.gz|zip|tar|tar\.gz"
BLOCKED_FILES=$(git diff --cached --name-only | grep -E "\.($BLOCKED_EXT)$")
if [ -n "$BLOCKED_FILES" ]; then
    echo -e "${RED}❌ ERROR: Binary/data files detected:${NC}"
    echo "$BLOCKED_FILES"
    echo "Store data files externally (S3, etc.)."
    EXIT_CODE=1
fi

if [ $EXIT_CODE -eq 0 ]; then
    echo -e "${GREEN}✅ Pre-commit checks passed${NC}"
fi

exit $EXIT_CODE
