# ── Required: Slack ──────────────────────────────────────────────────
# From https://api.slack.com/apps → your app → OAuth & Basic Information
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Channel where Pagemenot posts results (no # prefix)
PAGEMENOT_CHANNEL=incidents

# ── Trigger modes (all enabled by default) ───────────────────────────
# Channels to passively monitor for alert-looking messages (comma-separated)
# PAGEMENOT_ALERT_CHANNELS=alerts,incidents

# Disable any trigger mode you don't want:
# PAGEMENOT_ENABLE_CHANNEL_MONITOR=true   # auto-triage messages in watched channels
# PAGEMENOT_ENABLE_MENTIONS=true          # respond to @Pagemenot mentions
# PAGEMENOT_ENABLE_SLASH_COMMAND=true     # respond to /pagemenot triage
# PAGEMENOT_ENABLE_WEBHOOKS=true          # receive POSTs from PagerDuty/Grafana/etc.

# ── LLM ──────────────────────────────────────────────────────────────
#
# COMPLIANCE NOTE: External LLM providers (OpenAI, Anthropic, Gemini) receive
# tool outputs — Prometheus metrics, log lines, GitHub PR diffs, runbook text.
# For SOC 2 / HIPAA / PCI-DSS / ISO 27001 environments:
#   - Use Ollama (self-hosted, nothing leaves your network) ← recommended default
#   - Or use OpenAI Enterprise / Google Vertex AI with a signed DPA
#   - Standard consumer API tiers are NOT suitable for production SRE use
#
# ── Option A: Self-hosted (recommended for production SRE teams) ──────
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
OLLAMA_URL=http://localhost:11434

# ── Option B: External API (requires enterprise plan + signed DPA) ────
# Pagemenot will refuse to start without LLM_EXTERNAL_ENTERPRISE_CONFIRMED=true
# Only set this after confirming zero-data-retention agreement with your provider.
#
# LLM_EXTERNAL_ENTERPRISE_CONFIRMED=true
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=AIza...

# ── Vector store (embedded — no separate service needed) ─────────────
# ChromaDB runs embedded inside the container. Override if needed.
# CHROMA_PATH=/app/data/chroma

# ── Optional integrations ────────────────────────────────────────────
# Add any. Each one upgrades that tool from mock → live data.
# Skip anything you don't use — mock fallbacks handle the rest.

# ── Metrics / observability ──────────────────────────────────────────
# ── Prometheus ───────────────────────────────────────────────────────
# Self-hosted:
# PROMETHEUS_URL=http://prometheus:9090

# AWS Managed Prometheus (AMP):
# PROMETHEUS_URL=https://aps-workspaces.us-east-1.amazonaws.com/workspaces/<id>
# PROMETHEUS_AUTH_TOKEN=<sigv4-token>   # use aws-sigv4-proxy or pre-signed token

# Google Cloud Managed Prometheus:
# PROMETHEUS_URL=https://monitoring.googleapis.com/v1/projects/<project>/location/global/prometheus
# PROMETHEUS_AUTH_TOKEN=<gcp-access-token>

# Grafana Cloud (uses Grafana Cloud Prometheus endpoint):
# PROMETHEUS_URL=https://prometheus-prod-<n>-prod-<region>.grafana.net
# PROMETHEUS_AUTH_TOKEN=<grafana-cloud-api-key>

# ── Grafana ───────────────────────────────────────────────────────────
# Self-hosted:
# GRAFANA_URL=http://grafana:3000
# GRAFANA_API_KEY=glsa_...

# Grafana Cloud:
# GRAFANA_URL=https://<stack-slug>.grafana.net
# GRAFANA_API_KEY=glsa_...
# GRAFANA_ORG_ID=<numeric-org-id>

# ── Loki ──────────────────────────────────────────────────────────────
# Self-hosted:
# LOKI_URL=http://loki:3100

# Grafana Cloud (Loki):
# LOKI_URL=https://logs-prod-<n>.grafana.net
# LOKI_AUTH_TOKEN=<grafana-cloud-api-key>
# LOKI_ORG_ID=<numeric-org-id>        # X-Scope-OrgID header (multi-tenant)

# DATADOG_API_KEY=...
# DATADOG_APP_KEY=...
# DATADOG_SITE=datadoghq.com          # or datadoghq.eu, us3.datadoghq.com, etc.

# NEWRELIC_API_KEY=NRAK-...
# NEWRELIC_ACCOUNT_ID=...

# ── Alerting / on-call ───────────────────────────────────────────────
# PAGERDUTY_API_KEY=...               # REST API key — used to create incidents when AI can't resolve
# OPSGENIE_API_KEY=...

# ── Jira Service Management ──────────────────────────────────────────
# JIRA_SM_URL=https://<workspace>.atlassian.net
# JIRA_SM_EMAIL=...
# JIRA_SM_API_TOKEN=...              # https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_SM_PROJECT_KEY=...            # e.g. PMN, OPS
# JIRA_SM_ISSUE_TYPE=Service Request # issue type name in your JSM project
# JIRA_SM_SERVICE_DESK_ID=...        # auto-discovered if unset
# JIRA_SM_REQUEST_TYPE_ID=...        # auto-discovered if unset

# ── Source control / deploy correlation ──────────────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_ORG=your-org

# ── Execution ────────────────────────────────────────────────────────
# KUBECONFIG_PATH=/app/kubeconfig    # path inside container — mount via docker-compose volumes
# PAGEMENOT_EXEC_ENABLED=true        # default true — enables runbook execution pipeline
# PAGEMENOT_EXEC_DRY_RUN=true        # default true — logs steps, no real commands; set false for live execution
# PAGEMENOT_APPROVAL_GATE=false      # default false — set true to require human approval for [NEEDS APPROVAL] steps
# PAGEMENOT_EXEC_NAMESPACE=production # k8s namespace substituted for {{ namespace }} in runbook exec tags
# PAGEMENOT_ONCALL_CHANNEL=escalated  # Slack channel for critical/high escalation pings
# PAGEMENOT_AUTOAPPROVE_DELAY=900     # seconds before auto-executing [AUTO-SAFE] steps
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/pagemenot-exec
# AWS_REGION=us-east-1

# ── Webhook HMAC secrets (optional) ──────────────────────────────────
# Set to enable signature verification on incoming webhooks.
# If unset, pagemenot logs a warning and accepts unsigned requests.
# WEBHOOK_SECRET_PAGERDUTY=...
# WEBHOOK_SECRET_GRAFANA=...
# WEBHOOK_SECRET_ALERTMANAGER=...
# WEBHOOK_SECRET_DATADOG=...
# WEBHOOK_SECRET_OPSGENIE=...
# WEBHOOK_SECRET_NEWRELIC=...
# WEBHOOK_SECRET_GENERIC=...

# ── Approval state persistence (optional) ────────────────────────────
# If set, approval requests survive bot restarts and work across multiple instances.
# Falls back to in-memory (lost on restart) if unset.
# REDIS_URL=redis://localhost:6379/0

# ── Rate limiting ────────────────────────────────────────────────────
# Applied per source IP to all /webhooks/* endpoints.
# Format: N/second | N/minute | N/hour
# PAGEMENOT_WEBHOOK_RATE_LIMIT=60/minute

# ── Misc ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
